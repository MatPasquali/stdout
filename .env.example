# Copy this file to `.env` and fill in a key. The pipeline prefers Groq, falls
# back to Gemini, and runs in extractive mode (no AI) if neither is set.

# Groq (preferido) — free tier generoso, sem cartão: https://console.groq.com/keys
GROQ_API_KEY=

# Gemini (fallback) — free tier mais apertado: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Opcional — sobrescrever os modelos padrão.
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash-lite
