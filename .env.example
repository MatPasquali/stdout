# Copy this file to `.env` and fill in your key.
#
# Free Gemini key (no credit card): https://aistudio.google.com/app/apikey
# Without it, the pipeline still runs in extractive mode (no AI writing).
GEMINI_API_KEY=

# Optional — override the Gemini model (default: gemini-2.5-flash-lite, which is
# on the free tier). Note: gemini-2.0-flash has NO free quota on new keys.
# GEMINI_MODEL=gemini-2.5-flash-lite
